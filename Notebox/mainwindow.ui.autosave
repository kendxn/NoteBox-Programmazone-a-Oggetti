  <property name="styleSheet">
   <string notr="true">/* Sfondo nero per tutta l'applicazione */
QMainWindow, QWidget#page_2 {
    background-color: #000000;
    color: #ffffff; /* Testo bianco di default */
}

/* Regola per i Frame con bordi bianchi arrotondati */
QFrame {
    border: 1px solid #ffffff;
    border-radius: 8px;
    background-color: #1a1a1a; /* Un grigio scurissimo per dare profondità */
    padding: 0px;
}

/* Eccezione: non vogliamo bordi bianchi attorno ai bottoni o agli input */
QPushButton, QLineEdit, QTextEdit, QDateTimeEdit {
    border: 1px solid #555555;
    border-radius: 8px;
    background-color: #333333;
    color: white;
    padding: 4px;
}

QLabel{
    border: 0px;
}

/* Effetto al passaggio del mouse sui bottoni */
QPushButton:hover {
    background-color: #444444;
    border: 1px solid #00aaff; /* Un tocco di azzurro al passaggio */
}</string>
  </property>
  <property name="toolButtonStyle">
   <enum>Qt::ToolButtonStyle::ToolButtonTextBesideIcon</enum>
