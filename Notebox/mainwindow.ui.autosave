                <property name="styleSheet">
                 <string notr="true">#labelLogo {
    /* Colore del testo (puoi usare un gradiente o un colore solido) */
    color: #ffffff; 
    
    /* Font: usane uno bold e moderno */
    font-family: &quot;Segoe UI&quot;, &quot;Arial&quot;, sans-serif;
    font-weight: bold;
    font-style: italic;
    
    /* Allineamento */
    qproperty-alignment: 'AlignCenter';
    
    /* Sfondo (opzionale, se vuoi un tocco di colore dietro) */
    background-color: transparent;
    
    /* Rimuove eventuali bordi ereditati dal resto dell'app */
    border: none;
    padding: 0px;
}</string>
                </property>
